{
    "pluginAlias": "WLED",
    "pluginType": "platform",
    "singular": true,
    "headerDisplay": "homebridge-simple-wled: Nearly complete HomeKit support for WLED. See the [Github project page](https://github.com/jstrausd/homebridge-simple-wled) for more documentation.",
    "footerDisplay": "Configure at least one WLED device with a valid IP address to enable the plugin.",
    "schema": {
        "type": "object",
        "properties": {
            "wleds": {
                "type": "array",
                "title": "wleds",
