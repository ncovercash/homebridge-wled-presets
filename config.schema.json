{
  "pluginAlias": "WLED Presets",
  "pluginType": "platform",
  "singular": true,
  "headerDisplay": "homebridge-wled-presets: HomeKit support for WLED focused on presets. See the [Github project page](https://github.com/ncovercash/homebridge-wled-presets) for more documentation.",
  "footerDisplay": "Configure at least one WLED device with a valid IP address to enable the plugin.",
  "schema": {
    "type": "object",
    "properties": {
      "wleds": {
        "type": "array",
        "title": "wleds",
        "items": {
          "type": "object",
          "title": "WLED instance",
          "properties": {
            "name": {
              "title": "WLED name",
              "description": "Name for this WLED instance.",
              "type": "string",
              "placeholder": "Enter WLED name",
              "required": true
            },
            "host": {
              "title": "WLED IP Address",
              "description": "IP address for this WLED instance, or a comma separated list of IP addresses.",
              "type": "string",
              "format": "ipv4",
              "placeholder": "Enter WLED IP address(es)",
              "required": true
            },
            "log": {
              "title": "Logging",
              "description": "Enable Logging/Debugging option",
              "type": "boolean",
              "required": false
            }
          }
        }
      }
    }
  }
}
