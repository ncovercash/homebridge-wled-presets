                    "type": "object",
                    "title": "WLED instance",
                    "properties": {
                        "name": {
                            "title": "WLED name",
                            "description": "Name for this WLED instance.",
                            "type": "string",
                            "placeholder": "Enter WLED name",
                            "required": true
                        },
                        "host": {
                            "title": "WLED IP Address",
                            "description": "IP address for this WLED instance.",
                            "type": "string",
                            "format": "ipv4",
                            "placeholder": "Enter WLED IP address",
                            "required": true
                        },
                        "effects": {
                            "title": "Effects",
                            "description": "Effects for this WLED instance. Select from the suggestions or type a custom effect name. Effects are validated against your WLED device's supported effects at startup - unsupported effects will show a warning but can still be used (for newer/older WLED versions or custom effects).",
