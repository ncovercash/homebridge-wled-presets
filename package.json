  "main": "dist/index.js",
  "scripts": {
    "clean": "rimraf ./dist",
    "build": "rimraf ./dist && tsc",
    "dev": "npm run build && npm link && homebridge",
    "prepublishOnly": "npm run build",
    "postpublish": "npm run clean",
    "test": "npm run build && npm link",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --fix --ext .ts"
  },
  "author": "Jonathan Strauss <office@jstrauss.at>",
  "engines": {
    "homebridge": ">=0.4.50",
    "node": ">=10.21.0"
  },
  "keywords": [
    "homebridge-simple-wled",
    "homebridge-plugin"
  ],
  "license": "ISC",
  "files": [
    "LICENSE",
    "dist"
  ],
  "funding": {
    "type": "paypal",
    "url": "https://paypal.me/jxnis"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/jstrausd/homebridge-simple-wled.git"
  },
  "bugs": {
    "url": "http://github.com/jstrausd/homebridge-simple-wled/issues"
  },
  "devDependencies": {
    "@types/node": "^17.0.8",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "eslint": "^8.54.0",
    "eslint-config-standard-with-typescript": "^40.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-n": "^16.3.1",
    "eslint-plugin-promise": "^6.1.1",
    "homebridge": "^1.3.9",
    "rimraf": "^3.0.2",
    "ts-node": "^10.4.0",
    "typescript": "^4.9.5",
    "typescript-axios-wb": "^1.0.3"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^0.0.19",
    "axios": "^0.20.0",
    "polling-to-event": "^2.1.0"
