{
  "name": "homebridge-simple-wled",
  "version": "2.0.2",
  "description": "An accessory plugin for homebridge to support WLED Strips",
  "main": "dist/index.js",
  "scripts": {
    "clean": "rimraf ./dist",
    "build": "rimraf ./dist && tsc",
    "dev": "npm run lint && npm run test && npm run build && npm link",
    "prepublishOnly": "npm run build",
    "postpublish": "npm run clean",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --fix --ext .ts"
  },
  "author": "Jonathan Strauss <office@jstrauss.at>",
  "engines": {
    "homebridge": "^1.8.0 || ^2.0.0",
    "node": ">=18.0.0 <21.0.0"
  },
  "keywords": [
    "homebridge-simple-wled",
    "homebridge-plugin"
  ],
  "license": "ISC",
  "files": [
    "LICENSE",
    "dist",
    "config.schema.json"
  ],
  "funding": {
    "type": "paypal",
    "url": "https://paypal.me/jxnis"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/jstrausd/homebridge-simple-wled.git"
  },
  "bugs": {
    "url": "http://github.com/jstrausd/homebridge-simple-wled/issues"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^0.0.19",
    "axios": "^1.6.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.8",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "eslint": "^8.57.0",
    "eslint-config-standard-with-typescript": "^40.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-n": "^16.3.1",
    "eslint-plugin-promise": "^6.1.1",
    "homebridge": "^1.8.0 || ^2.0.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.2.0"
  }
}
